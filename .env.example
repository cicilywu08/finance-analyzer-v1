# Copy to .env.local and fill in your own values. Never commit .env.local.

# Local Postgres (example: postgresql://USER:PASSWORD@localhost:5432/finance_analyzer)
DATABASE_URL=

# OpenAI — required for AI categorization and advisor insights
OPENAI_API_KEY=

# Set to "true" to allow uploads and DB writes (and to run schema init on startup)
ENABLE_DB_WRITE=true
